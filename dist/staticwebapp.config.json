{
  "routes": [
    {
      "route": "*.js",
      "headers": {
        "cache-control": "public, max-age=31536000"
      }
    },
    {
      "route": "*.css",
      "headers": {
        "cache-control": "public, max-age=31536000"
      }
    },
    {
      "route": "/index.html",
      "headers": {
        "cache-control": "no-cache, no-store, must-revalidate"
      }
    },
    {
      "route": "/*",
      "statusCode": 200,
      "file": "/index.html"
    }
  ]
}
