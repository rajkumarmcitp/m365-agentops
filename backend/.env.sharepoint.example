# ============================================================
# TenantGuard SharePoint Integration Configuration
# ============================================================
# Copy this to .env after creating SharePoint site and lists
# Follow SHAREPOINT_SETUP_GUIDE.md for step-by-step instructions

# Azure/Tenant Configuration
AZURE_TENANT_ID=b9cc8284-05ed-452f-877a-970779430dcb
AZURE_CLIENT_ID=04d3be8d-d433-4367-893e-eccc82190a11
AZURE_CLIENT_SECRET=your-client-secret-here

# SharePoint Configuration
# These must be filled in after creating the SharePoint site

# Site Configuration
SHAREPOINT_SITE_NAME=M365-AgentOps
SHAREPOINT_SITE_URL=https://nasstech.sharepoint.com/sites/M365-AgentOps
SHAREPOINT_SITE_ID=your-site-id-here

# List IDs (get these from SharePoint admin or PowerShell)
SHAREPOINT_ALERTS_LIST_ID=your-alerts-list-id-here
SHAREPOINT_CORRELATIONS_LIST_ID=your-correlations-list-id-here
SHAREPOINT_INVESTIGATIONS_LIST_ID=your-investigations-list-id-here

# ============================================================
# How to Get List IDs
# ============================================================
# Option 1: Via URL (when in the list)
# https://nasstech.sharepoint.com/sites/M365-AgentOps/_api/web/lists?$filter=displayName%20eq%20%27TenantGuard-Alerts%27
# Look for "Id" field in the response

# Option 2: Via PowerShell
# $lists = Get-PnPList -Includes Id
# foreach($list in $lists) { Write-Host "$($list.Title): $($list.Id)" }

# Option 3: Via SharePoint UI
# List → Settings → Look at URL for list ID (LibraryID parameter)

# ============================================================
# Optional Configuration
# ============================================================

# Backend Server
PORT=3000
NODE_ENV=production

# Frontend URL (for CORS)
FRONTEND_URL=https://proud-river-0f55f1e10.7.azurestaticapps.net

# SharePoint Sync
# How often to sync alerts from audit logs (minutes)
SHAREPOINT_SYNC_INTERVAL=5

# Retry Configuration
SHAREPOINT_MAX_RETRIES=3
SHAREPOINT_RETRY_DELAY=1000

# ============================================================
# Example (After Setup)
# ============================================================
# SHAREPOINT_SITE_NAME=M365-AgentOps
# SHAREPOINT_SITE_ID=d4571234-5678-90ab-cdef-1234567890ab
# SHAREPOINT_ALERTS_LIST_ID=abcd1234-5678-90ef-ghij-0987654321kl
# SHAREPOINT_CORRELATIONS_LIST_ID=efgh5678-1234-5678-klmn-1234567890op
# SHAREPOINT_INVESTIGATIONS_LIST_ID=ijkl9012-5678-1234-stuv-1234567890qr
