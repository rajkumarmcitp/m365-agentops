# =============================================================
# M365 AgentOps - Environment Configuration
# =============================================================

# Azure AD / Graph API Configuration
AZURE_TENANT_ID=your-tenant-id.onmicrosoft.com
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Optional: Threat Protection Policy Names
# Set these to display real policy names in the Email Security dashboard
# If not set, the system will try to fetch from Graph API or PowerShell
# Format: comma-separated policy names or single policy name

THREAT_POLICY_SAFE_LINKS=Office 365 Safe Links Policy, Custom Policy 1
THREAT_POLICY_SAFE_ATTACHMENTS=ATP - Safe Attachments Policy
THREAT_POLICY_ANTI_PHISHING=Office 365 Anti-Phishing, Custom Phishing Policy
THREAT_POLICY_ANTI_SPAM=Default Hosted Content Filter Policy
THREAT_POLICY_ANTI_MALWARE=Default Malware Filter Policy
THREAT_POLICY_ZAP_ENABLED=true
THREAT_POLICY_AIR_ENABLED=true
THREAT_POLICY_THREAT_EXPLORER_ENABLED=true

# SharePoint Configuration (Optional)
SHAREPOINT_SITE_ID=your-sharepoint-site-id
SHAREPOINT_LIST_ALERTS=Alerts
SHAREPOINT_LIST_INVESTIGATIONS=Investigations

# Exchange Online Configuration (Optional)
EXCHANGE_ORGANIZATION=yourtenant.onmicrosoft.com
EXCHANGE_CERT_PATH=/path/to/cert.pfx
EXCHANGE_CERT_PASSWORD=your-cert-password

# Claude API (Optional - for AI features)
CLAUDE_API_KEY=your-claude-api-key

# Environment
NODE_ENV=production
