# Development Environment Configuration
# Copy this file to .env.development and customize as needed
# This file is for LOCAL DEVELOPMENT ONLY with demo data

# API Configuration (local backend or demo)
VITE_API_BASE=http://localhost:3000
VITE_API_TIMEOUT=30000

# Demo mode
VITE_USE_DEMO=true

# SharePoint Configuration
VITE_SHAREPOINT_SITE=root

# Logging
VITE_LOG_LEVEL=debug

# Feature Flags (all enabled in dev)
VITE_FEATURE_TENANTGUARD=true
VITE_FEATURE_USER_INVESTIGATION=true
VITE_FEATURE_GRAPH_API=true
VITE_FEATURE_PORTAL=true
