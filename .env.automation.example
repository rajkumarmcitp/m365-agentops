# ============================================================
# Azure Automation Webhook URLs
# ============================================================
# Copy this file to .env and fill in the actual webhook URLs
# from your Azure Automation Account
#
# How to get the URLs:
# 1. Azure Portal → Automation Account → Runbooks
# 2. Select runbook → Webhooks
# 3. Copy the URL and paste below

# EXCHANGE SERVICES
AUTOMATION_EXCHANGE_DG_WEBHOOK=https://eus2-v2.azure-automation.net/webhooks?token=YOUR_WEBHOOK_TOKEN_HERE

# (Add these as you create the runbooks)
# AUTOMATION_EXCHANGE_SHARED_MAILBOX_WEBHOOK=...
# AUTOMATION_EXCHANGE_ROOMS_WEBHOOK=...
# AUTOMATION_EXCHANGE_EMAIL_SERVICES_WEBHOOK=...

# TEAMS
# AUTOMATION_TEAMS_OPERATIONS_WEBHOOK=...

# SHAREPOINT
# AUTOMATION_SHAREPOINT_SITES_WEBHOOK=...
# AUTOMATION_ONEDRIVE_MANAGEMENT_WEBHOOK=...
# AUTOMATION_EXTERNAL_SHARING_WEBHOOK=...

# USER & LICENSE MANAGEMENT
# AUTOMATION_USER_ACCESS_WEBHOOK=...
# AUTOMATION_LICENSE_MANAGEMENT_WEBHOOK=...
# AUTOMATION_COPILOT_MANAGEMENT_WEBHOOK=...

# POWER PLATFORM & INTUNE
# AUTOMATION_POWER_PLATFORM_WEBHOOK=...
# AUTOMATION_INTUNE_DEVICES_WEBHOOK=...

# GUEST LIFECYCLE
# AUTOMATION_GUEST_LIFECYCLE_WEBHOOK=...
