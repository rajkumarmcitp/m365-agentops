# Production Environment Configuration
# Set these environment variables on your production server/deployment
# ⚠️ NEVER commit actual production credentials to git - only use this as a template
# Deploy this via GitHub Secrets, Azure Key Vault, or App Service Configuration

# ============================================================
# API Configuration (Real Azure Backend)
# ============================================================
VITE_API_BASE=https://m365ops-api-gtbgezb9c7bgata7.centralus-01.azurewebsites.net
VITE_API_TIMEOUT=30000
VITE_BACKEND_URL=https://m365ops-api-gtbgezb9c7bgata7.centralus-01.azurewebsites.net

# ============================================================
# Authentication Configuration
# ============================================================
VITE_MSAL_CLIENT_ID=YOUR_AZURE_AD_CLIENT_ID
VITE_MSAL_AUTHORITY=https://login.microsoftonline.com/common
VITE_MSAL_REDIRECT_URI=https://m365ops.contoso.com

# ============================================================
# SharePoint Configuration
# ============================================================
VITE_SHAREPOINT_SITE=/sites/M365AgentOps
VITE_SHAREPOINT_LIST_ID=YOUR_SHAREPOINT_LIST_ID

# ============================================================
# Real Data Mode
# ============================================================
VITE_USE_DEMO=false

# ============================================================
# Logging
# ============================================================
VITE_LOG_LEVEL=warn

# ============================================================
# Feature Flags
# ============================================================
VITE_FEATURE_TENANTGUARD=true
VITE_FEATURE_USER_INVESTIGATION=true
VITE_FEATURE_GRAPH_API=true
VITE_FEATURE_PORTAL=true
VITE_TENANTGUARD_ENABLED=true
VITE_CHANGE_INTELLIGENCE_ENABLED=true

# ============================================================
# HOTFIXES & TEMPORARY PRODUCTION WORKAROUNDS
# ============================================================
# Set these to 'true' to enable temporary fixes for production issues
# These do NOT affect your local development
# Remove these lines once the underlying issue is permanently fixed

# TenantGuard alerts performance issue (set to true to disable alerts)
VITE_HOTFIX_SKIP_ALERTS=false

# API timeout reduction (milliseconds)
# VITE_HOTFIX_REDUCE_TIMEOUT=true
# VITE_HOTFIX_API_TIMEOUT=15000

# Disable specific features (comma-separated)
# VITE_HOTFIX_DISABLE_FEATURES=feature1,feature2

# Override dashboard refresh interval (milliseconds)
# VITE_HOTFIX_DASHBOARD_REFRESH=120000

# Disable security page
# VITE_HOTFIX_DISABLE_SECURITY=false

# Disable M365 Config page
# VITE_HOTFIX_DISABLE_M365CONFIG=false

# Disable Change Intelligence
# VITE_HOTFIX_DISABLE_CHANGEINTEL=false
