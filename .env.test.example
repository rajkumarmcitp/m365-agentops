# ============================================
# M365 AgentOps - TEST ENVIRONMENT EXAMPLE
# ============================================
# Copy this file to .env.local and set TEST_MODE=true
# DO NOT commit actual secrets to git!

# ============================================
# TEST MODE - Use this for safe testing
# ============================================
# Set to 'true' to enable test mode
# All data will be saved to *-TEST lists in SharePoint
# No production data will be modified
VITE_TEST_MODE=true

# ============================================
# Azure AD Configuration (Test App)
# ============================================
# Create a SEPARATE Azure AD app for testing
# Name it "M365 AgentOps - TEST" in Azure Portal
# DO NOT use your production app registration

# Your test app's Client ID
# Example format: 12345678-1234-1234-1234-123456789012
VITE_AZURE_CLIENT_ID=your-test-app-client-id-here

# Your test app's Client Secret (keep this secret!)
# Example format: abc123def456ghi789jkl012mno345
VITE_AZURE_CLIENT_SECRET=your-test-app-secret-here

# Your Azure AD Tenant ID
# Example format: 87654321-4321-4321-4321-210987654321
VITE_AZURE_TENANT_ID=your-test-tenant-id-here

# Your test app's Redirect URI
# Example: https://localhost:5173/auth/callback
VITE_AZURE_REDIRECT_URI=https://localhost:5173/auth/callback

# ============================================
# SharePoint Configuration (Test Site)
# ============================================
# Create a TEST SharePoint site for testing
# URL: /sites/M365AgentOps-Test (optional)
#
# Required SharePoint lists (will be created automatically):
# - Setup-Configuration-TEST
# - Requests-TEST
# - Audit-TEST
# - Correlations-TEST

# Your test SharePoint site ID
# Get this from: SharePoint site → Settings → Site information
# Example format: site-id-12345678
VITE_SHAREPOINT_SITE=test-site-id-here

# ============================================
# Backend Configuration
# ============================================
# API URL for backend calls
VITE_API_URL=http://localhost:3001

# Node environment
VITE_USER_NODE_ENV=development

# ============================================
# Server Configuration (Backend)
# ============================================
# Port to run on (if running backend separately)
PORT=3001

# ============================================
# Optional: For Test Tenant Setup
# ============================================
# If using a completely separate test tenant:

# Test Tenant ID (different from main tenant)
# AZURE_TENANT_ID=test-tenant-id

# Test SharePoint Site ID
# SHAREPOINT_SITE_ID=test-site-id

# Test App registration credentials
# AZURE_CLIENT_ID=test-app-client-id
# AZURE_CLIENT_SECRET=test-app-secret

# ============================================
# How to Use This File
# ============================================
#
# 1. Copy this file:
#    cp .env.test.example .env.local
#
# 2. Fill in your test credentials:
#    - Test Azure AD App (register in Azure Portal)
#    - Test SharePoint Site (or use existing)
#
# 3. Start dev server with test environment:
#    source .env.local
#    npm run dev
#
# 4. Or set variables inline:
#    VITE_TEST_MODE=true npm run dev
#
# 5. Navigate to: http://localhost:5173/setup-wizard
#
# 6. You should see yellow banner: "TEST MODE ENABLED"
#
# ============================================
# Important Notes
# ============================================
#
# • TEST MODE ONLY: Set VITE_TEST_MODE=true
#   - Saves data to Setup-Configuration-TEST list
#   - Does NOT modify production data
#   - Safe to test repeatedly
#
# • Create separate Azure AD app:
#   - Go to Azure Portal
#   - Azure AD → App registrations → New registration
#   - Name: "M365 AgentOps - TEST"
#   - Copy: Client ID, Secret, Tenant ID
#   - Add Redirect URI: https://localhost:5173/auth/callback
#
# • Create test SharePoint lists:
#   - Setup-Configuration-TEST
#   - Requests-TEST
#   - Audit-TEST
#   - Correlations-TEST
#   (Or the wizard can create them)
#
# • Never commit real secrets:
#   - Keep this file in .gitignore
#   - Use separate credentials for test
#   - Rotate secrets after testing
#
# ============================================
# Testing Steps
# ============================================
#
# 1. Setup Phase
#    - Enable TEST_MODE
#    - Point to test app registration
#    - Point to test SharePoint site
#
# 2. Run Wizard Steps 1-5
#    - Fill out each step
#    - Click "Complete Step X → Step Y"
#    - Watch data save to SharePoint-TEST
#
# 3. Verify Test Data
#    - Check SharePoint lists
#    - Look for entries in Setup-Configuration-TEST
#    - Verify no entries in production lists
#
# 4. Run Verification (Step 5)
#    - All 5 tests should pass
#    - See "Setup Complete! 🎉" message
#
# 5. Clean Up
#    - Delete test data from SharePoint
#    - Or just leave it and re-run tests
#    - Disable TEST_MODE when done
#
# ============================================
